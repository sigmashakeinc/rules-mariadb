# mariadb_write_safety.rules
# Technology: mariadb | Capability: write

rule mariadb-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_mariadb_PATTERN"
  MESSAGE "Blocked an unsafe pattern in mariadb. Use the recommended best practices for 2025/2026."
}

rule mariadb-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_mariadb_API"
  MESSAGE "You are using an outdated API for mariadb. Please upgrade to the newer API."
}
